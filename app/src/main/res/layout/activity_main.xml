<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_surface">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="108dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/navBackground"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_main_bottom_nav"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/navLibrary"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/navBackground"
                app:layout_constraintEnd_toStartOf="@id/homeButtonWrapper"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@id/navBackground"
                app:layout_constraintTop_toTopOf="@id/navBackground">

                <ImageView
                    android:id="@+id/ivLibrary"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_nav_library"
                    app:tint="@color/main_nav_unselected" />

                <TextView
                    android:id="@+id/tvLibrary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/main_nav_library"
                    android:textColor="@color/main_nav_unselected"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navUser"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/navBackground"
                app:layout_constraintStart_toEndOf="@id/homeButtonWrapper"
                app:layout_constraintTop_toTopOf="@id/navBackground">

                <ImageView
                    android:id="@+id/ivUser"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_nav_user"
                    app:tint="@color/main_nav_unselected" />

                <TextView
                    android:id="@+id/tvUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/main_nav_user"
                    android:textColor="@color/main_nav_unselected"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navSetting"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/navBackground"
                app:layout_constraintEnd_toEndOf="@id/navBackground"
                app:layout_constraintTop_toTopOf="@id/navBackground">

                <ImageView
                    android:id="@+id/ivSetting"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_nav_setting"
                    app:tint="@color/main_nav_unselected" />

                <TextView
                    android:id="@+id/tvSetting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/main_nav_setting"
                    android:textColor="@color/main_nav_unselected"
                    android:textSize="12sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/homeButtonWrapper"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_main_home_button"
                android:elevation="8dp"
                app:layout_constraintBottom_toBottomOf="@id/navBackground"
                app:layout_constraintEnd_toEndOf="@id/navBackground"
                app:layout_constraintStart_toStartOf="@id/navBackground"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/navHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_home_scan" />
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
