<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/auth_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/auth_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="92dp"
        android:padding="14dp">

        <FrameLayout
            android:id="@+id/coverFrame"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_library_cover_pink"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvCollectionInitial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/auth_surface"
                android:textSize="22sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvCollectionName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/auth_text_primary"
            android:textSize="18sp"
            app:layout_constraintEnd_toStartOf="@id/btnCollectionMenu"
            app:layout_constraintStart_toEndOf="@id/coverFrame"
            app:layout_constraintTop_toTopOf="@id/coverFrame" />

        <TextView
            android:id="@+id/tvCollectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="6dp"
            android:textColor="@color/auth_text_hint"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/btnCollectionMenu"
            app:layout_constraintStart_toEndOf="@id/coverFrame"
            app:layout_constraintTop_toBottomOf="@id/tvCollectionName" />

        <FrameLayout
            android:id="@+id/btnCollectionMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="@id/coverFrame"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/coverFrame">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/library_menu_content_desc"
                android:src="@drawable/ic_library_more" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
