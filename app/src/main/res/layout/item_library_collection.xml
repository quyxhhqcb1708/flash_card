<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/auth_surface"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/auth_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="116dp"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/coverFrame"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_library_cover_pink"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvCollectionInitial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/auth_surface"
                android:textSize="22sp"
                tools:text="I" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvCollectionName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/auth_text_primary"
            android:textSize="18sp"
            app:layout_constraintEnd_toStartOf="@id/btnCollectionMenu"
            app:layout_constraintStart_toEndOf="@id/coverFrame"
            app:layout_constraintTop_toTopOf="@id/coverFrame"
            tools:text="IELTS Speaking" />

        <TextView
            android:id="@+id/tvCollectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="6dp"
            android:textColor="@color/auth_text_hint"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/btnCollectionMenu"
            app:layout_constraintStart_toEndOf="@id/coverFrame"
            app:layout_constraintTop_toBottomOf="@id/tvCollectionName"
            tools:text="12 flashcards" />

        <FrameLayout
            android:id="@+id/btnCollectionMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/coverFrame">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/library_menu_content_desc"
                android:src="@drawable/ic_library_more" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvPracticeSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_library_stat_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:textColor="@color/library_chip_text"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/coverFrame"
            tools:text="8 ready / 4 mastered" />

        <TextView
            android:id="@+id/tvLastPractice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/auth_text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPracticeSummary"
            tools:text="Last practice: No practice yet" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
