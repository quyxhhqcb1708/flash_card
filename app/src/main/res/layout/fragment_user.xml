<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_surface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="32dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

        <View
            android:id="@+id/topBubble"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="-82dp"
            android:layout_marginEnd="-88dp"
            android:background="@drawable/bg_auth_bubble"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/bottomBubble"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginStart="-118dp"
            android:layout_marginBottom="-110dp"
            android:background="@drawable/bg_auth_bubble"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvUserTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/main_user_title"
            android:textColor="@color/auth_text_primary"
            android:textSize="26sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/avatarFrame"
            android:layout_width="108dp"
            android:layout_height="108dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_user_avatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUserTitle">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_user"
                app:tint="@color/auth_surface" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvNameLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/main_user_name"
            android:textColor="@color/auth_text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/avatarFrame" />

        <TextView
            android:id="@+id/tvNameValue"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_auth_input_normal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:textColor="@color/auth_text_primary"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNameLabel"
            tools:text="Name User" />

        <TextView
            android:id="@+id/tvEmailLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/auth_email"
            android:textColor="@color/auth_text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNameValue" />

        <TextView
            android:id="@+id/tvEmailValue"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_auth_input_normal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:textColor="@color/auth_text_primary"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
            tools:text="1234@gmail.com" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_auth_input_normal"
            android:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/main_logout"
            android:textAllCaps="false"
            android:textColor="@color/auth_text_secondary"
            android:textSize="17sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEmailValue" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteAccount"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_delete_button"
            android:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/main_delete_account"
            android:textAllCaps="false"
            android:textColor="@color/auth_surface"
            android:textSize="17sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnLogout" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
