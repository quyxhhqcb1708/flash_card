<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_surface"
    android:paddingTop="32dp"
    android:paddingHorizontal="16dp">

    <View
        android:id="@+id/topBubble"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="-82dp"
        android:layout_marginEnd="-88dp"
        android:background="@drawable/bg_auth_bubble"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottomBubble"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginStart="-118dp"
        android:layout_marginBottom="-110dp"
        android:background="@drawable/bg_auth_bubble"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvPracticeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="@string/practice_title"
        android:textColor="@color/auth_text_primary"
        android:textSize="26sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPracticeTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/overviewCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_library_overview_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/practice_title"
                    android:textColor="@color/auth_text_primary"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvPracticeSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/practice_subtitle"
                    android:textColor="@color/auth_text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDueTodayCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_library_stat_chip"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/library_chip_text"
                        android:textSize="13sp"
                        tools:text="8 due today" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvTotalCardsCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_library_stat_chip"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/library_chip_text"
                        android:textSize="13sp"
                        tools:text="24 total cards" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvLearningCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_library_stat_chip"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/library_chip_text"
                        android:textSize="13sp"
                        tools:text="12 learning" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvMasteredCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_library_stat_chip"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/library_chip_text"
                        android:textSize="13sp"
                        tools:text="5 mastered" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartDueReview"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_auth_primary_button"
                    android:backgroundTint="@null"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/practice_start_due"
                    android:textAllCaps="false"
                    android:textColor="@color/auth_surface"
                    app:backgroundTint="@null"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPracticeAll"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_library_secondary_button"
                    android:backgroundTint="@null"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/practice_start_all"
                    android:textAllCaps="false"
                    android:textColor="@color/auth_gradient_end"
                    app:backgroundTint="@null"
                    app:strokeWidth="0dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/emptyStateContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="42dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="136dp"
                    android:layout_height="136dp"
                    android:background="@drawable/bg_library_empty_circle">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_nav_card"
                        app:tint="@color/auth_gradient_end" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/practice_empty_title"
                    android:textColor="@color/auth_text_primary"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/practice_empty_subtitle"
                    android:textColor="@color/auth_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/scheduleSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/practice_schedule_title"
                    android:textColor="@color/auth_text_primary"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/practice_schedule_subtitle"
                    android:textColor="@color/auth_text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/scheduleContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
