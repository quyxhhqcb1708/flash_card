<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_progress_stat_card"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/coverFrame"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_library_cover_blue">

            <TextView
                android:id="@+id/tvCollectionInitial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/auth_surface"
                android:textSize="20sp"
                tools:text="I" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCollectionName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/auth_text_primary"
                android:textSize="17sp"
                tools:text="Favourite" />

            <TextView
                android:id="@+id/tvCollectionMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/auth_text_secondary"
                android:textSize="13sp"
                tools:text="12 cards • 8 practiced" />
        </LinearLayout>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/auth_text_hint" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDueChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_progress_collection_chip_due"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textColor="@color/progress_due"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="3 due today"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvLearningChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_progress_collection_chip_upcoming"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textColor="@color/progress_learning"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="5 building"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvMasteredChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_progress_collection_chip_mastered"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textColor="@color/progress_stable"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="4 mastered"
            tools:visibility="visible" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/progress_mastery"
            android:textColor="@color/auth_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvMasteryValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textColor="@color/auth_text_primary"
            android:textSize="13sp"
            tools:text="Mastery 42%" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressMastery"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0"
        android:progressBackgroundTint="@color/library_progress_track"
        android:progressTint="@color/progress_learning" />

    <TextView
        android:id="@+id/tvAccuracyValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/auth_text_secondary"
        android:textSize="13sp"
        tools:text="Accuracy 78%" />

</LinearLayout>
