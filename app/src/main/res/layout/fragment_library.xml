<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_surface"
    android:paddingTop="32dp"
    android:paddingHorizontal="16dp">

    <View
        android:id="@+id/topBubble"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="-82dp"
        android:layout_marginEnd="-88dp"
        android:background="@drawable/bg_auth_bubble"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottomBubble"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginStart="-118dp"
        android:layout_marginBottom="-110dp"
        android:background="@drawable/bg_auth_bubble"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/btnAddCollection"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_scan_icon_button"
        android:contentDescription="@string/library_add_collection"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_library_add"
            app:tint="@color/auth_text_primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvLibraryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="@string/library_title"
        android:textColor="@color/auth_text_primary"
        android:textSize="26sp"
        app:layout_constraintBottom_toBottomOf="@id/btnAddCollection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnAddCollection" />

    <LinearLayout
        android:id="@+id/searchContainer"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_library_search"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLibraryTitle">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_library_search" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="@string/library_search_hint"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/auth_text_primary"
            android:textColorHint="@color/auth_text_hint"
            android:textSize="15sp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/emptyStateContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="42dp"
                android:paddingBottom="32dp">

                <FrameLayout
                    android:layout_width="136dp"
                    android:layout_height="136dp"
                    android:background="@drawable/bg_library_empty_circle">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_nav_library"
                        app:tint="@color/auth_gradient_end" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/library_empty_title"
                    android:textColor="@color/auth_text_primary"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvEmptySubtitle"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/library_empty_subtitle"
                    android:textColor="@color/auth_text_secondary"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateNow"
                    android:layout_width="190dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="22dp"
                    android:background="@drawable/bg_auth_primary_button"
                    android:backgroundTint="@null"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/library_create_now"
                    android:textAllCaps="false"
                    android:textColor="@color/auth_surface"
                    app:backgroundTint="@null"
                    app:strokeWidth="0dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSearchEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="@string/library_no_search_result"
                android:textColor="@color/auth_text_secondary"
                android:textSize="15sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/collectionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
